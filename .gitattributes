# 모든 텍스트 파일 줄바꿈 자동 처리 (Windows CRLF → LF 통일)
* text=auto

# 특정 파일 명시
*.java   text eol=lf
*.kt     text eol=lf
*.groovy text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.sql    text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.json   text eol=lf
*.xml    text eol=lf
*.properties text eol=lf

# 바이너리 파일 (줄바꿈 처리 제외)
*.jar    binary
*.class  binary
*.png    binary
*.jpg    binary
*.gif    binary
*.ico    binary
